# Copy to .env for local dev. Never commit .env.
# In GitHub Actions, these are set as repository secrets / variables.

# --- Slack ---
SLACK_BOT_TOKEN=xoxb-replace-me

# --- Google service account ---
# In GH Actions: paste full JSON contents into the GOOGLE_SERVICE_ACCOUNT_JSON secret.
# Locally: either set the JSON inline, or point GOOGLE_SERVICE_ACCOUNT_FILE at a file.
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_SERVICE_ACCOUNT_FILE=./.secrets/service-account.json

# --- Cloudflare R2 (name universe storage) ---
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=snagged-names
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com

# --- Anthropic (fuzzy parsing: Atom Wholesale doc) ---
ANTHROPIC_API_KEY=

# --- Per-source API keys / tokens ---
EFTY_PARTNER_TOKEN=
CF_BROWSER_ACCOUNT_ID=
CF_BROWSER_API_TOKEN=
NAMESILO_API_KEY=
GODADDY_API_KEY=
GODADDY_API_SECRET=

# --- Slack channel IDs (override defaults set in sources.yaml) ---
SLACK_CHANNEL_SNAP=C09B1P21YQ0
SLACK_CHANNEL_AUCTIONS=C096AT8BECS
